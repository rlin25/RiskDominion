# Risk: Dominion environment configuration. Copy to `.env` and fill in values.
# `.env` is gitignored (it holds the secret ANTHROPIC_API_KEY).

# SpacetimeDB connection. Use the IPv4 literal 127.0.0.1 (not localhost):
# browsers may resolve localhost to IPv6 (::1), which the IPv4-only server
# isn't listening on.
SPACETIMEDB_URI=ws://127.0.0.1:3000

# Client (Vite) config. Vite reads this same file (envDir in vite.config.ts) and
# only exposes VITE_-prefixed vars to the browser, so the API key below stays out
# of the client bundle.
VITE_SPACETIMEDB_URI=ws://127.0.0.1:3000
VITE_MODULE_NAME=risk-dominion

# Anthropic API (used server-side from SpacetimeDB *procedures*, Slice 2+).
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=your_key_here
